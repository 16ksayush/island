# ============================================================
# Archive 19 — environment template
# Copy to `.env` and fill in REAL values locally.
# `.env` is git-ignored; this `.env.example` is the ONLY env
# file tracked in git. Never put real values in this file.
# ============================================================

# SECRET — Cloudinary connection string (the standard Cloudinary SDK var):
#   cloudinary://<api_key>:<api_secret>@<cloud_name>
# Read server-side only via os.environ.get("CLOUDINARY_URL"). The api_secret is
# used ONLY for the server-side Admin API (HTTP basic auth) to list image
# metadata; it must NEVER be logged, committed, or sent to the browser. Image
# DELIVERY uses Cloudinary's keyless public CDN (https://res.cloudinary.com/...),
# so the browser never sees any credential. Set it as an env var on the host
# (Render/Railway), not in any committed file.
CLOUDINARY_URL=

# CONFIG (not a secret) — background image re-list interval, seconds.
# 1800 = re-list Cloudinary (metadata only) every 30 min so new photos appear
# without a redeploy. Unset/0 disables the background poll (hermetic for
# local dev and CI).
IMAGE_SYNC_INTERVAL_SECONDS=

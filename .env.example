# ============================================================
# Archive 19 — environment template
# Copy to `.env` and fill in REAL values locally.
# `.env` is git-ignored; this `.env.example` is the ONLY env
# file tracked in git. Never put real values in this file.
# ============================================================

# SECRET — Google Drive API key. Read server-side only via
# os.environ.get("GD_API_KEY"). NEVER commit the real value,
# never log it, never send it to the browser or interpolate
# it into templates/URLs. Set it as an env var on the host
# (Render/Railway), not in any committed file.
GD_API_KEY=

# CONFIG (not a secret) — parent Google Drive folder ID (or link)
# holding the numbered child folders (0..18) and `missing/`.
# The folder must be shared "Anyone with the link -> Viewer"
# for an API-key (vs service-account) to read it.
GD_ROOT_FOLDER=
